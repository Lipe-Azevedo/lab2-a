import java.util.Random;
import java.util.concurrent.Semaphore;

public class JoiningClang {
    static Semaphore mutex = new Semaphore(1);
    static Semaphore semWaitJoin = new Semaphore(0);
    static int finishedThreads = 0;
    static int totalSum = 0;
    static int targetWait;

    static class RequestTask implements Runnable {
        public void run() {
            try {
                Random rand = new Random();
                int n = rand.nextInt(5);
                Thread.sleep(n * 1000);
                
                mutex.acquire();
                totalSum += n;
                finishedThreads++;
                if (finishedThreads == targetWait) semWaitJoin.release();
                mutex.release();
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
            }
        }
    }

    public static int gateway(int nthreads, int waitNthreads) {
        targetWait = waitNthreads;
        finishedThreads = 0;
        totalSum = 0;

        Thread[] threads = new Thread[nthreads];
        
        for (int i = 0; i < nthreads; i++) {
            threads[i] = new Thread(new RequestTask());
            threads[i].start();
        }

        try {
            semWaitJoin.acquire();
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }

        return totalSum;
    }
}